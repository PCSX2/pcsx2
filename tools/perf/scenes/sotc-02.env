# Scene: Shadow of the Colossus (SCUS-97472) — savestate slot 02 (user-chosen "good
# location"). SotC is VU-geometry heavy (large single-mesh colossi, big draw distance).
# Assets are copyrighted (not checked in); paths reflect this dev box.
LABEL="SotC — slot 02"
ISO_ROOT="${ISO_ROOT:-/home/bmd/dev/ps2/My Sony PlayStation 2 (USA) Collection}"
ISO="$ISO_ROOT/Shadow of the Colossus (USA).iso"
SAVESTATE="$HOME/.config/PCSX2/sstates/SCUS-97472 (C19A374E).02.p2s"
FRAMES=600           # same N every run
RENDERERS="vk null"  # vk = whole-system (M2 GPU-driver heavy); null = CPU-emulation shape
