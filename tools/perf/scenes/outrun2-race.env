# Scene: OutRun 2006 - Coast 2 Coast (SLES-53998, PAL) — in-race savestate slot 03.
# User-reported below-60fps on SD865 (2026-07-01). Savestate captured in pcsx2-qt on
# the device, so it lives in the SHARED Qt config dir (/storage/.config/PCSX2), not
# the perf rig's HOME (/storage/pcsx2/.config) — absolute path below.
# Assets are copyrighted (not checked in); paths reflect the SD865 device layout.
LABEL="OutRun 2006 C2C — race (slot 03)"
ISO_ROOT="${ISO_ROOT:-/storage/roms/ps2}"
ISO="$ISO_ROOT/OutRun 2006 - Coast 2 Coast (Europe) (En,Fr,De,Es,It).iso"
SAVESTATE="/storage/.config/YAPS2/sstates/SLES-53998 (03F8D7E0).03.p2s"
FRAMES=600           # same N every run
RENDERERS="vk null"  # vk = whole-system (representative on SD865/Adreno); null = CPU-only shape
