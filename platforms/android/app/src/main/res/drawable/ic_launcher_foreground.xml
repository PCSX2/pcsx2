<?xml version="1.0" encoding="utf-8"?>
<!--
  savetowerforeground is a fully pre-composed icon (tower + its own dark radial
  background) that fills the whole 1024px square. Dropping it straight into an
  adaptive-icon <foreground> with gravity="fill" stretches it across the entire
  108dp layer, so the launcher mask (which only shows the centre ~72dp safe zone)
  crops the dark margins and zooms hard into the tower. Inset the artwork so the
  full composition lands inside the safe zone and the tower keeps its breathing
  room; the ~18% margin shows the solid #01071C adaptive background, which matches
  the artwork's dark edges so the seam is invisible.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:inset="18%">
    <bitmap
        android:antialias="true"
        android:dither="true"
        android:gravity="fill"
        android:src="@drawable/savetowerforeground" />
</inset>
