#/bin/bash

set -u
set -e
trap onexit INT
trap onexit TERM
trap onexit EXIT

onexit()
{
	if [ -d $OUTDIR ]; then
		rm -rf $OUTDIR
	fi
}

runme()
{
	echo \*\*\* $* | sed "s@$EXEDIR@\$EXEDIR@g" | sed "s@$IMGDIR@\$IMGDIR@g" |
		sed "s@$JAVA@\$JAVA@g" | sed "s@:@WITH_JNA@@@g" |
		sed "s@$OUTDIR@\$OUTDIR@g"
	"$@"
}

IMGDIR=@CMAKE_SOURCE_DIR@/testimages
OUTDIR=`mktemp -d /tmp/__tjdecomptest_output.XXXXXX`
EXEDIR=@CMAKE_BINARY_DIR@
JAVA="@Java_JAVA_EXECUTABLE@"
if [ -z "$JAVA" ]; then
	JAVA=java
fi
JNAARGS="-cp $EXEDIR/jna/turbojpeg-jna.jar:@WITH_JNA@ -Djna.library.path=$EXEDIR"
TJDECOMP=$EXEDIR/tjdecomp
JAVAARG=

if [ -d $OUTDIR ]; then
	rm -rf $OUTDIR
fi
mkdir -p $OUTDIR

while [ $# -gt 0 ]; do
	case "$1" in
	-jna)
		JAVAARG=-jna
		TJDECOMP="$JAVA $JNAARGS TJDecomp"
		;;
	esac
	shift
done

exec >$EXEDIR/test/tjdecomptest$JAVAARG.log 2>&1

echo "EXEDIR: $EXEDIR"
echo "IMGDIR: $IMGDIR"
echo "OUTDIR: $OUTDIR"
echo

SUBSAMPOPT=(444 422 440 420 411 441 410 24 32)
SAMPOPT=(1x1 2x1 1x2 2x2 4x1 1x4 4x2 2x4 3x2)

for precision in 8 12; do
	if [ $precision -le 8 ]; then
		RGBIMG=$IMGDIR/testorig.ppm
		RGBFMTARG=
		GRAYIMG=$IMGDIR/testorig.png
		GRAYFMTARG=-png
		basename=testorig
	else
		RGBIMG=$IMGDIR/monkey16.png
		RGBFMTARG=-png
		GRAYIMG=$IMGDIR/monkey16.pgm
		GRAYFMTARG=
		basename=monkey16
	fi
	RGBEXT=${RGBIMG##*.}
	GRAYEXT=${GRAYIMG##*.}

	for sampi in {0..8}; do
		iccarg=
		if [ $sampi = 3 ]; then
			iccarg="-icc $IMGDIR/test1.icc"
		elif [ $sampi = 4 -a "$RGBEXT" = "png" ]; then
			iccarg=-noicc
		fi
		runme $EXEDIR/cjpeg -pre $precision -sa ${SAMPOPT[$sampi]} $iccarg \
			-outf $OUTDIR/${basename}-${SUBSAMPOPT[$sampi]}.jpg $RGBIMG
		if [ $precision -gt 8 ]; then
			runme $EXEDIR/cjpeg -pre 8 -sa ${SAMPOPT[$sampi]} $iccarg \
				-outf $OUTDIR/${basename}-${SUBSAMPOPT[$sampi]}-8.jpg $RGBIMG
		fi
	done
	runme $EXEDIR/cjpeg -pre $precision \
		-outf $OUTDIR/${basename}-gray.jpg $GRAYIMG
	if [ $precision -gt 8 ]; then
		runme $EXEDIR/cjpeg -pre 8 \
			-outf $OUTDIR/${basename}-gray-8.jpg $GRAYIMG
	fi
	echo

	for subsamp in ${SUBSAMPOPT[*]} gray; do
		for croparg in "" "-cr 14x14+23+23" "-cr 21x21+4+4" "-cr 18x18+13+13" \
			"-cr 21x21+0+0" "-cr 24x26+20+18"; do
			if [[ "$croparg" != "" && "$subsamp" = "32" ]]; then
				continue
			fi
			for scalearg in "" "-s 16/8" "-s 15/8" "-s 14/8" "-s 13/8" "-s 12/8" \
				"-s 11/8" "-s 10/8" "-s 9/8" "-s 7/8" "-s 6/8" "-s 5/8" "-s 4/8" \
				"-s 3/8" "-s 2/8" "-s 1/8"; do
				if [[ ("$scalearg" = "-s 1/8" || "$scalearg" = "-s 2/8" || \
					"$scalearg" = "-s 3/8") && "$croparg" != "" ]]; then
					continue
				fi
				for nsarg in "" "-nos"; do
					if [[ "$nsarg" = "-nos" && "$subsamp" != "422" && \
						"$subsamp" != "420" && "$subsamp" != "440" ]]; then
						continue
					fi
					for dctarg in "" "-dc fa"; do
						if [[ "$dctarg" = "-dc fa" && \
							("$scalearg" != "-s 4/8" || \
								("$subsamp" != "420" && "$subsamp" != "32")) && \
							"$scalearg" != "" ]]; then
							continue
						fi
						if [ "$subsamp" = "gray" ]; then
							runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
								$OUTDIR/${basename}-$subsamp.jpg \
								$OUTDIR/${basename}-tjdecomp.$GRAYEXT
							runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
								$GRAYFMTARG -outf $OUTDIR/${basename}-djpeg.$GRAYEXT \
								$OUTDIR/${basename}-$subsamp.jpg
							$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
								$OUTDIR/${basename}-djpeg.$GRAYEXT | sed "s@$OUTDIR@\$OUTDIR@g"
							cmp $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
								$OUTDIR/${basename}-djpeg.$GRAYEXT
							rm $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
								$OUTDIR/${basename}-djpeg.$GRAYEXT
							echo

							runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
								-r $OUTDIR/${basename}-$subsamp.jpg \
								$OUTDIR/${basename}-tjdecomp.$RGBEXT
							runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
								$RGBFMTARG -rg -outf $OUTDIR/${basename}-djpeg.$RGBEXT \
								$OUTDIR/${basename}-$subsamp.jpg
							$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT | sed "s@$OUTDIR@\$OUTDIR@g"
							cmp $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT
							rm $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT
							echo

							if [ $precision -gt 8 ]; then
								runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
									$OUTDIR/${basename}-$subsamp-8.jpg \
									$OUTDIR/${basename}-tjdecomp.$GRAYEXT
								runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
									$GRAYFMTARG -outf $OUTDIR/${basename}-djpeg.$GRAYEXT \
									$OUTDIR/${basename}-$subsamp-8.jpg
								$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT | \
									sed "s@$OUTDIR@\$OUTDIR@g"
								cmp $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT
								rm $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT
								echo

								runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
									-r $OUTDIR/${basename}-$subsamp-8.jpg \
									$OUTDIR/${basename}-tjdecomp.$RGBEXT
								runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
									$RGBFMTARG -rg -outf $OUTDIR/${basename}-djpeg.$RGBEXT \
									$OUTDIR/${basename}-$subsamp-8.jpg
								$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT | \
									sed "s@$OUTDIR@\$OUTDIR@g"
								cmp $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT
								rm $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT
								echo
							fi
						else
							iccarg=
							if [ "$subsamp" = "420" ]; then
								iccarg="-icc $OUTDIR/${basename}-tjdecomp.icc"
							elif [ "$subsamp" = "411" -a "$RGBEXT" = "png" ]; then
								iccarg=-noicc
							fi
							runme $TJDECOMP $croparg $dctarg $nsarg $scalearg $iccarg \
								$OUTDIR/${basename}-$subsamp.jpg \
								$OUTDIR/${basename}-tjdecomp.$RGBEXT
							if [ "$subsamp" = "420" ]; then
								iccarg="-icc $OUTDIR/${basename}-djpeg.icc"
							elif [ "$subsamp" = "411" -a "$RGBEXT" = "png" ]; then
								iccarg=-noicc
							fi
							runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg $iccarg \
								$RGBFMTARG -outf $OUTDIR/${basename}-djpeg.$RGBEXT \
								$OUTDIR/${basename}-$subsamp.jpg
							if [ "$subsamp" = "420" ]; then
								$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.icc \
									$OUTDIR/${basename}-djpeg.icc | sed "s@$OUTDIR@\$OUTDIR@g"
								cmp $OUTDIR/${basename}-tjdecomp.icc \
									$OUTDIR/${basename}-djpeg.icc
								rm $OUTDIR/${basename}-tjdecomp.icc \
									$OUTDIR/${basename}-djpeg.icc
							fi
							$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT | sed "s@$OUTDIR@\$OUTDIR@g"
							cmp $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT
							rm $OUTDIR/${basename}-tjdecomp.$RGBEXT \
								$OUTDIR/${basename}-djpeg.$RGBEXT
							echo

							if [[ "$nsarg" = "" ]]; then
								runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
									-g $OUTDIR/${basename}-$subsamp.jpg \
									$OUTDIR/${basename}-tjdecomp.$GRAYEXT
								runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
									$GRAYFMTARG -gr -outf $OUTDIR/${basename}-djpeg.$GRAYEXT \
									$OUTDIR/${basename}-$subsamp.jpg
								$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT | \
									sed "s@$OUTDIR@\$OUTDIR@g"
								cmp $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT
								rm $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
									$OUTDIR/${basename}-djpeg.$GRAYEXT
								echo
							fi

							if [ $precision -gt 8 ]; then
								iccarg=
								if [ "$subsamp" = "420" ]; then
									iccarg="-icc $OUTDIR/${basename}-tjdecomp.icc"
								elif [ "$subsamp" = "411" -a "$RGBEXT" = "png" ]; then
									iccarg=-noicc
								fi
								runme $TJDECOMP $croparg $dctarg $nsarg $scalearg $iccarg \
									$OUTDIR/${basename}-$subsamp-8.jpg \
									$OUTDIR/${basename}-tjdecomp.$RGBEXT
								if [ "$subsamp" = "420" ]; then
									iccarg="-icc $OUTDIR/${basename}-djpeg.icc"
								elif [ "$subsamp" = "411" -a "$RGBEXT" = "png" ]; then
									iccarg=-noicc
								fi
								runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg $iccarg \
									$RGBFMTARG -outf $OUTDIR/${basename}-djpeg.$RGBEXT \
									$OUTDIR/${basename}-$subsamp-8.jpg
								if [ "$subsamp" = "420" ]; then
									$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.icc \
										$OUTDIR/${basename}-djpeg.icc | sed "s@$OUTDIR@\$OUTDIR@g"
									cmp $OUTDIR/${basename}-tjdecomp.icc \
										$OUTDIR/${basename}-djpeg.icc
									rm $OUTDIR/${basename}-tjdecomp.icc \
										$OUTDIR/${basename}-djpeg.icc
								fi
								$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT | \
									sed "s@$OUTDIR@\$OUTDIR@g"
								cmp $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT
								rm $OUTDIR/${basename}-tjdecomp.$RGBEXT \
									$OUTDIR/${basename}-djpeg.$RGBEXT
								echo

								if [[ "$nsarg" = "" ]]; then
									runme $TJDECOMP $croparg $dctarg $nsarg $scalearg \
										-g $OUTDIR/${basename}-$subsamp-8.jpg \
										$OUTDIR/${basename}-tjdecomp.$GRAYEXT
									runme $EXEDIR/djpeg $croparg $dctarg $nsarg $scalearg \
										$GRAYFMTARG -gr -outf $OUTDIR/${basename}-djpeg.$GRAYEXT \
										$OUTDIR/${basename}-$subsamp-8.jpg
									$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
										$OUTDIR/${basename}-djpeg.$GRAYEXT | \
										sed "s@$OUTDIR@\$OUTDIR@g"
									cmp $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
										$OUTDIR/${basename}-djpeg.$GRAYEXT
									rm $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
										$OUTDIR/${basename}-djpeg.$GRAYEXT
									echo
								fi
							fi
						fi
					done
				done
			done
		done
		rm $OUTDIR/${basename}-$subsamp.jpg
		if [ $precision -gt 8 ]; then
			rm $OUTDIR/${basename}-$subsamp-8.jpg
		fi
	done
done

for precision in {2..16}; do
	if [ $precision -le 8 ]; then
		RGBIMG=$IMGDIR/testorig.ppm
		RGBFMTARG=
		GRAYIMG=$IMGDIR/testorig.png
		GRAYFMTARG=-png
		basename=testorig
	else
		RGBIMG=$IMGDIR/monkey16.png
		RGBFMTARG=-png
		GRAYIMG=$IMGDIR/monkey16.pgm
		GRAYFMTARG=
		basename=monkey16
	fi
	RGBEXT=${RGBIMG##*.}
	GRAYEXT=${GRAYIMG##*.}

	runme $EXEDIR/cjpeg -pre $precision -l 1 \
		-outf $OUTDIR/${basename}-rgb.jpg $RGBIMG
	echo

	runme $TJDECOMP $OUTDIR/${basename}-rgb.jpg \
		$OUTDIR/${basename}-tjdecomp.$RGBEXT
	runme $EXEDIR/djpeg $RGBFMTARG -outf $OUTDIR/${basename}-djpeg.$RGBEXT \
		$OUTDIR/${basename}-rgb.jpg
	$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$RGBEXT \
		$OUTDIR/${basename}-djpeg.$RGBEXT | sed "s@$OUTDIR@\$OUTDIR@g"
	cmp $OUTDIR/${basename}-tjdecomp.$RGBEXT $OUTDIR/${basename}-djpeg.$RGBEXT
	rm $OUTDIR/${basename}-tjdecomp.$RGBEXT $OUTDIR/${basename}-djpeg.$RGBEXT
	rm $OUTDIR/${basename}-rgb.jpg
	echo

	runme $EXEDIR/cjpeg -pre $precision -l 1 \
		-outf $OUTDIR/${basename}-gray.jpg $GRAYIMG
	echo

	runme $TJDECOMP $OUTDIR/${basename}-gray.jpg \
		$OUTDIR/${basename}-tjdecomp.$GRAYEXT
	runme $EXEDIR/djpeg $GRAYFMTARG -outf $OUTDIR/${basename}-djpeg.$GRAYEXT \
		$OUTDIR/${basename}-gray.jpg
	$EXEDIR/test/md5sum $OUTDIR/${basename}-tjdecomp.$GRAYEXT \
		$OUTDIR/${basename}-djpeg.$GRAYEXT | sed "s@$OUTDIR@\$OUTDIR@g"
	cmp $OUTDIR/${basename}-tjdecomp.$GRAYEXT $OUTDIR/${basename}-djpeg.$GRAYEXT
	rm $OUTDIR/${basename}-tjdecomp.$GRAYEXT $OUTDIR/${basename}-djpeg.$GRAYEXT
	rm $OUTDIR/${basename}-gray.jpg
	echo
done

echo "GREAT SUCCESS!"
