MD5_MONKEY16_GRAY2RGB_256_JPG=e2c2737b631bfb6201cfc505cf193d9e

MD5_TESTORIG_RGB_JPG=71d7dca7216d78641519683e588842f3

MD5_TESTORIG_RGB_128_PPM=431681fc0a2cb55dcd4743c82904547d
MD5_TESTORIG_RGB_128_JPG=8a3dcd318359a29f653a2d975af61985
MD5_TESTORIG_12_RGB_128_JPG=95ca159af10b726e5f89774329215982
MD5_TESTORIG_RGB_256_PPM=cdf99d1c5c7789fdce63c263b401c038
MD5_TESTORIG_RGB_256_JPG=af7e5ae99617cc02faeb3fd4369f29f4
