#!/bin/bash

set -u
set -e
trap onexit INT
trap onexit TERM
trap onexit EXIT

onexit()
{
	if [ -d $OUTDIR ]; then
		rm -rf $OUTDIR
	fi
}

runme()
{
	echo \*\*\* $*
	$*
}

IMGDIR=@CMAKE_SOURCE_DIR@/testimages
OUTDIR=`mktemp -d /tmp/__indexedcolortest_output.XXXXXX`
EXEDIR=@CMAKE_BINARY_DIR@

if [ -d $OUTDIR ]; then
	rm -rf $OUTDIR
fi
mkdir -p $OUTDIR

exec >$EXEDIR/test/indexedcolortest.log 2>&1

MD5_MONKEY16_RGB_JPG=3f9ebcf7dbafbed33cb139106936f7ce

MD5_MONKEY16_RGB_128_PPM=05e39e86013050dea2a2acae4590d73c
MD5_MONKEY16_RGB_128_JPG=5402cb3a65fb1cbc7a7ebee181217498
MD5_MONKEY16_RGB_256_PPM=33f0c9615a5d5b3f34c5b7448deec18f
MD5_MONKEY16_RGB_256_JPG=8134084d3e26761c70b4b814f95c1761

MD5_MONKEY16_RGB2GRAY_128_PGM=fe8b2940504ba8e4534f71dce38bf493
MD5_MONKEY16_RGB2GRAY_128_JPG=b101265afe908155e8697aa66249a9e7
MD5_MONKEY16_RGB2GRAY_256_PGM=2931ed6abb354faa9e72ea64b842f7c5
