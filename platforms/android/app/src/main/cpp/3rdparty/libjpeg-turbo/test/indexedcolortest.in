MD5_TESTORIG_RGB2GRAY_128_PGM=f6a2e8120ba8ed972ab78c01916cc287
MD5_TESTORIG_RGB2GRAY_128_JPG=5e484699442589c6afa75d51243801ce
MD5_TESTORIG_12_RGB2GRAY_128_JPG=2380f5f8dec12f99f05d2caf9c89e5c9
MD5_TESTORIG_RGB2GRAY_256_PGM=aa847f6c7c7ce2677dc61abf72358cc6
