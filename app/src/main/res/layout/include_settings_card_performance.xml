<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="?attr/colorSurfaceVariant"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_section_performance"
            android:textColor="?attr/colorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/settings_cpu_core"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/sp_cpu_core"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_hw_readbacks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_hardware_readbacks"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/skip_duplicate_frames"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_skip_duplicate_frames"
            app:useMaterialThemeColors="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_hw_download_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_hw_download_mode_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_hw_download_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="0"
                android:valueFrom="0"
                android:valueTo="3"
                android:stepSize="1"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_ee_cycle_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_ee_cycle_rate_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_ee_cycle_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="0"
                android:valueFrom="-3"
                android:valueTo="3"
                android:stepSize="1"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_ee_cycle_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_ee_cycle_skip_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_ee_cycle_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="0"
                android:valueFrom="0"
                android:valueTo="3"
                android:stepSize="1"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_vu_thread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_vu_thread_mtvu"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_wait_loop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_wait_loop_detection"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_intc_spin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_intc_spin_detection"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_mvu_flag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_mvu_flag_hack"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_instant_vu1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings_instant_vu1"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_fast_cdvd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/settings_fast_cdvd"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/sw_frame_limiter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_frame_limiter"
            app:useMaterialThemeColors="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_fps_limit_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_custom_fps_limit_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_fps_limit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="60"
                android:valueFrom="30"
                android:valueTo="180"
                android:stepSize="1"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/settings_framerate_control_title"
            android:textColor="?attr/colorPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_ntsc_framerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_ntsc_framerate_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_ntsc_framerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="59.94"
                android:valueFrom="20.0"
                android:valueTo="120.0"
                android:stepSize="0.01"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_pal_framerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_pal_framerate_default"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sb_pal_framerate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:value="50.00"
                android:valueFrom="20.0"
                android:valueTo="120.0"
                android:stepSize="0.01"
                app:haloRadius="16dp"
                app:labelBehavior="gone"
                app:tickVisible="false" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_framerates"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_framerate_reset" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
